{
    "name": "kennofizet/release-support-backend",
    "description": "Release support backend package for issue reporting, draw annotations, and app version update workflow.",
    "type": "library",
    "license": "MIT",
    "version": "0.1.0",
    "keywords": [
        "laravel",
        "support",
        "release",
        "reporting",
        "backend"
    ],
    "authors": [
        {
            "name": "KennoFizet",
            "email": "kennofizetreal@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.0",
        "kennofizet/packages-core-backend": "*"
    },
    "autoload": {
        "psr-4": {
            "Kennofizet\\ReleaseSupport\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kennofizet\\ReleaseSupport\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Kennofizet\\ReleaseSupport\\ReleaseSupportServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
